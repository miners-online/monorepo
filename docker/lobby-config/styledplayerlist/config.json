{
  "config_version": 2,
  "__comment": "Before changing anything, see https://github.com/Patbox/StyledPlayerList#configuration",
  "default_style": "default",
  "messages": {
    "switch": "Your player list style has been changed to: <gold>${style}</gold>",
    "unknown": "<red>This style doesn't exist!</red>",
    "no_permission": "<red>You don't have required permissions!</red>"
  },
  "player": {
    "modify_name": true,
    "modify_right_text": false,
    "modify_list_order": false,
    "modify_visibility": false,
    "passthrough": false,
    "hidden": false,
    "format": "%player:displayname%",
    "right_text": "",
    "update_on_chat_message": true,
    "update_tick_time": 20,
    "styles": [
        {
            "require": {
                "type": "permission",
                "permission": "group:lead_admin"
            },
            "format": "<gray>[<red>Lead Admin</red>]</gray> <yellow>%player:name_unformatted%</yellow>"
        },
        {
            "require": {
                "type": "permission",
                "permission": "group:admin"
            },
            "format": "<gray>[<red>Admin</red>]</gray> <yellow>%player:name_unformatted%</yellow>"
        },
        {
            "require": {
                "type": "permission",
                "permission": "group:moderator"
            },
            "format": "<gray>[<red>Moderator</red>]</gray> <yellow>%player:name_unformatted%</yellow>"
        },
        {
            "require": {
                "type": "permission",
                "permission": "group:member"
            },
            "format": "<gray>[<pink>Member</pink>]</gray> <yellow>%player:name_unformatted%</yellow>"
        },
        {
            "require": {
                "type": "permission",
                "permission": "group:vip"
            },
            "format": "<gray>[<gold>VIP</gold>]</gray> <yellow>%player:name_unformatted%</yellow>"
        }
    ]
  },
  "client_show_in_singleplayer": true
}